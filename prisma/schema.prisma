generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskType {
  TASK
  STORY
  BUG
}

model User {
  id              String      @id
  email           String      @unique
  name            String?
  avatarUrl       String?
  createdTasks    Task[]      @relation("TaskCreator")
  assignedTasks   Task[]      @relation("TaskAssignee")
  memberProjects  Project[]   @relation("ProjectMembers")
  createdProjects Project[]   @relation("ProjectCreator")
  lists           BoardList[] @relation("ListCreator")
  createdAt       DateTime    @default(now())
}

model Task {
  id          String       @id @default(uuid())
  title       String
  description String?
  userId      String       // Creator
  creator     User         @relation("TaskCreator", fields: [userId], references: [id])
  assigneeId  String?
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [id])
  listId      String
  list        BoardList    @relation(fields: [listId], references: [id], onDelete: Cascade)
  position    Int          @default(0)
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  type        TaskType     @default(TASK)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime     @default(now())

  @@index([userId, listId])
  @@index([listId, position])
}

model Project {
  id        String      @id @default(uuid())
  name      String
  color     String
  userId    String      // Creator
  creator   User        @relation("ProjectCreator", fields: [userId], references: [id])
  members   User[]      @relation("ProjectMembers")
  createdAt DateTime    @default(now())
  lists     BoardList[]

  @@index([userId])
}

model BoardList {
  id        String   @id @default(uuid())
  name      String
  color     String
  userId    String
  creator   User     @relation("ListCreator", fields: [userId], references: [id])
  projectId String
  position  Int      @default(0)
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks     Task[]

  @@index([projectId, position])
  @@index([userId])
}
